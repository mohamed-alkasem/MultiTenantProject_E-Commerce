@model CartPageViewModel
@{
    var s = Model.Store;
    bool isAr = s.IsAr;
    string slug = s.StoreSlug;
    var cart = Model.Cart;
    ViewData["Title"] = isAr ? "سلة التسوق" : "Shopping Cart";
}

<div class="container page-section">
    <h4 class="fw-bold mb-4">
        <i class="bi bi-cart3 me-2"></i>@(isAr ? "سلة التسوق" : "Shopping Cart")
    </h4>

    @if (cart is null || !cart.Items.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-cart-x fs-1 d-block mb-3 opacity-25"></i>
            <h5>@(isAr ? "سلتك فارغة" : "Your cart is empty")</h5>
            <p class="mb-4">@(isAr ? "لم تضف أي منتجات بعد" : "You haven't added any products yet")</p>
            <a href="/s/@slug/Products" class="btn btn-primary px-4">
                @(isAr ? "تسوق الآن" : "Shop Now")
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-lg-8">
                <div class="card">
                    <div class="card-body p-0">
                        @foreach (var item in cart.Items)
                        {
                            <div class="d-flex align-items-center gap-3 p-3 border-bottom">
                                @if (!string.IsNullOrEmpty(item.ProductImageUrl))
                                {
                                    <img src="@item.ProductImageUrl" alt="@item.ProductName"
                                         class="rounded" style="width:64px;height:64px;object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="rounded d-flex align-items-center justify-content-center bg-light text-muted"
                                         style="width:64px;height:64px;font-size:1.5rem;">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }
                                <div class="flex-grow-1">
                                    <div class="fw-medium">@item.ProductName</div>
                                    @if (!string.IsNullOrEmpty(item.VariantName))
                                    {
                                        <div class="text-muted small">@item.VariantName</div>
                                    }
                                    <div class="product-price">@item.UnitPrice.ToString("N2")</div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <form method="post" action="/s/@slug/Cart/Update">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartItemId" value="@item.Id" />
                                        <div class="input-group input-group-sm" style="width:110px;">
                                            <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                                    class="btn btn-outline-secondary">-</button>
                                            <span class="form-control text-center">@item.Quantity</span>
                                            <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                                    class="btn btn-outline-secondary">+</button>
                                        </div>
                                    </form>
                                    <form method="post" action="/s/@slug/Cart/Remove">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartItemId" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                title="@(isAr ? "حذف" : "Remove")">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                                <div class="fw-bold text-end" style="min-width:70px;">
                                    @item.LineTotal.ToString("N2")
                                </div>
                            </div>
                        }
                        <div class="p-3 text-end">
                            <form method="post" action="/s/@slug/Cart/Clear"
                                  onsubmit="return confirm('@(isAr ? "هل تريد إفراغ السلة؟" : "Clear cart?")')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash me-1"></i>@(isAr ? "إفراغ السلة" : "Clear Cart")
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="card">
                    <div class="card-header fw-semibold">@(isAr ? "ملخص الطلب" : "Order Summary")</div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">@(isAr ? "المجموع الفرعي" : "Subtotal")</span>
                            <span class="fw-medium">@cart.Subtotal.ToString("N2")</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between mb-3">
                            <span class="fw-bold">@(isAr ? "الإجمالي" : "Total")</span>
                            <span class="fw-bold product-price" style="font-size:1.1rem;">@cart.TotalAmount.ToString("N2")</span>
                        </div>
                        <a href="/s/@slug/Checkout" class="btn btn-primary w-100">
                            @(isAr ? "إتمام الطلب" : "Proceed to Checkout")
                            <i class="bi bi-arrow-@(isAr ? "right" : "left") ms-2"></i>
                        </a>
                        <a href="/s/@slug/Products" class="btn btn-outline-secondary w-100 mt-2">
                            @(isAr ? "متابعة التسوق" : "Continue Shopping")
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
