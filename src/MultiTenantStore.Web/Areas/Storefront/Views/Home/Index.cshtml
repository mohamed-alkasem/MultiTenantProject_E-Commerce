@model HomePageViewModel
@{
    var s = Model.Store;
    bool isAr = s.IsAr;
    ViewData["Title"] = isAr ? "الرئيسية" : "Home";
    string slug = s.StoreSlug;
}

@* Hero *@
<div class="store-hero">
    <div class="container text-center">
        <h1 class="fw-bold mb-2" style="font-size:2rem;">@s.StoreName</h1>
        <p class="mb-3 opacity-75">@(isAr ? "اكتشف منتجاتنا المميزة" : "Discover our products")</p>
        <a href="/s/@slug/Products" class="btn btn-light btn-lg px-4">
            @(isAr ? "تسوق الآن" : "Shop Now")
            <i class="bi bi-arrow-@(isAr ? "right" : "left") ms-2"></i>
        </a>
    </div>
</div>

<div class="container page-section">

    @* Categories *@
    @if (Model.Categories.Any())
    {
        <div class="mb-4">
            <h5 class="fw-bold mb-3">@(isAr ? "الفئات" : "Categories")</h5>
            <div class="d-flex flex-wrap gap-2">
                <a href="/s/@slug/Products" class="category-pill">
                    @(isAr ? "الكل" : "All")
                </a>
                @foreach (var cat in Model.Categories)
                {
                    <a href="/s/@slug/Products?categoryId=@cat.Id" class="category-pill">
                        @cat.Name
                    </a>
                }
            </div>
        </div>
    }

    @* Featured Products *@
    @if (Model.FeaturedProducts.Any())
    {
        <div class="mb-2">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h5 class="fw-bold mb-0">@(isAr ? "منتجات مميزة" : "Featured Products")</h5>
                <a href="/s/@slug/Products" class="btn btn-sm btn-outline-primary">
                    @(isAr ? "عرض الكل" : "View All")
                </a>
            </div>
            <div class="row g-3">
                @foreach (var p in Model.FeaturedProducts)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="product-card card h-100">
                            <a href="/s/@slug/Products/Details/@p.Slug" class="text-decoration-none">
                                @if (!string.IsNullOrEmpty(p.PrimaryImageUrl))
                                {
                                    <img src="@p.PrimaryImageUrl" alt="@p.Name" class="card-img-top" />
                                }
                                else
                                {
                                    <div class="product-img-placeholder"><i class="bi bi-image"></i></div>
                                }
                            </a>
                            <div class="card-body d-flex flex-column p-3">
                                <a href="/s/@slug/Products/Details/@p.Slug" class="text-decoration-none text-dark">
                                    <div class="fw-medium mb-1" style="font-size:0.9rem; line-height:1.3;">@p.Name</div>
                                </a>
                                @if (!string.IsNullOrEmpty(p.ShortDescription))
                                {
                                    <div class="text-muted mb-2" style="font-size:0.78rem;">@p.ShortDescription</div>
                                }
                                <div class="mt-auto">
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <span class="product-price">@p.Price.ToString("N2")</span>
                                        @if (p.CompareAtPrice.HasValue && p.CompareAtPrice > p.Price)
                                        {
                                            <span class="product-price-old">@p.CompareAtPrice.Value.ToString("N2")</span>
                                        }
                                    </div>
                                    <form method="post" action="/s/@slug/Cart/Add">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@p.Id" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <button type="submit" class="btn-add-cart">
                                            <i class="bi bi-cart-plus me-1"></i>
                                            @(isAr ? "أضف للسلة" : "Add to Cart")
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-box-seam fs-1 d-block mb-3 opacity-25"></i>
            <h6>@(isAr ? "لا توجد منتجات حتى الآن" : "No products yet")</h6>
        </div>
    }
</div>
