@model ProductListViewModel
@{
    var s = Model.Store;
    bool isAr = s.IsAr;
    string slug = s.StoreSlug;
    ViewData["Title"] = Model.CategoryName is not null
        ? Model.CategoryName
        : (isAr ? "المنتجات" : "Products");
}

<div class="container page-section">

    @* Page header *@
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h4 class="fw-bold mb-1">@ViewData["Title"]</h4>
            <p class="text-muted small mb-0">@Model.TotalCount @(isAr ? "منتج" : "products")</p>
        </div>
    </div>

    @* Categories filter *@
    @if (Model.Categories.Any())
    {
        <div class="d-flex flex-wrap gap-2 mb-4">
            <a href="/s/@slug/Products" class="category-pill @(Model.CategoryId is null ? "active" : "")">
                @(isAr ? "الكل" : "All")
            </a>
            @foreach (var cat in Model.Categories)
            {
                <a href="/s/@slug/Products?categoryId=@cat.Id" class="category-pill @(Model.CategoryId == cat.Id ? "active" : "")">
                    @(isAr && !string.IsNullOrEmpty(cat.NameAr) ? cat.NameAr : cat.Name)
                </a>
            }
        </div>
    }

    @* Search box *@
    <form method="get" action="/s/@slug/Products" class="mb-4">
        @if (Model.CategoryId.HasValue)
        {
            <input type="hidden" name="categoryId" value="@Model.CategoryId" />
        }
        <div class="input-group" style="max-width:420px;">
            <input type="text" name="search" value="@Model.Search" class="form-control"
                   placeholder="@(isAr ? "ابحث عن منتج..." : "Search products...")" />
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a href="/s/@slug/Products@(Model.CategoryId.HasValue ? $"?categoryId={Model.CategoryId}" : "")" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </div>
    </form>

    @* Products grid *@
    @if (!Model.Products.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-search fs-1 d-block mb-3 opacity-25"></i>
            <p>@(isAr ? "لا توجد منتجات تطابق البحث" : "No products found")</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var p in Model.Products)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="product-card card h-100">
                        <a href="/s/@slug/Products/Details/@p.Slug" class="text-decoration-none">
                            @if (!string.IsNullOrEmpty(p.PrimaryImageUrl))
                            {
                                <img src="@p.PrimaryImageUrl" alt="@p.Name" class="card-img-top" />
                            }
                            else
                            {
                                <div class="product-img-placeholder"><i class="bi bi-image"></i></div>
                            }
                        </a>
                        <div class="card-body d-flex flex-column p-3">
                            <a href="/s/@slug/Products/Details/@p.Slug" class="text-decoration-none text-dark">
                                <div class="fw-medium mb-1" style="font-size:0.88rem; line-height:1.3;">
                                    @(isAr && !string.IsNullOrEmpty(p.NameAr) ? p.NameAr : p.Name)
                                </div>
                            </a>
                            @{
                                var pShortDesc = isAr && !string.IsNullOrEmpty(p.ShortDescriptionAr) ? p.ShortDescriptionAr : p.ShortDescription;
                            }
                            @if (!string.IsNullOrEmpty(pShortDesc))
                            {
                                <div class="text-muted mb-2" style="font-size:0.76rem;">@pShortDesc</div>
                            }
                            @if (p.IsFeatured)
                            {
                                <span class="badge bg-warning text-dark mb-2" style="font-size:0.65rem; width:fit-content;">
                                    @(isAr ? "مميز" : "Featured")
                                </span>
                            }
                            <div class="mt-auto">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="product-price">@p.Price.ToString("N2")</span>
                                    @if (p.CompareAtPrice.HasValue && p.CompareAtPrice > p.Price)
                                    {
                                        <span class="product-price-old">@p.CompareAtPrice.Value.ToString("N2")</span>
                                    }
                                </div>
                                <form method="post" action="/s/@slug/Cart/Add">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@p.Id" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <button type="submit" class="btn-add-cart">
                                        <i class="bi bi-cart-plus me-1"></i>@(isAr ? "أضف للسلة" : "Add to Cart")
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* Pagination *@
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        var href = $"/s/{slug}/Products?page={i}";
                        if (!string.IsNullOrEmpty(Model.Search)) href += $"&search={Uri.EscapeDataString(Model.Search)}";
                        if (Model.CategoryId.HasValue) href += $"&categoryId={Model.CategoryId}";
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link" href="@href">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>
