@model OrderConfirmationViewModel
@{
    var s = Model.Store;
    bool isAr = s.IsAr;
    string slug = s.StoreSlug;
    ViewData["Title"] = isAr ? "تم تأكيد طلبك" : "Order Confirmed";
}

<div class="container page-section">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6">
            <div class="card text-center p-4">
                <div class="mb-3" style="font-size:4rem; color:#2ecc71;">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <h4 class="fw-bold mb-2">@(isAr ? "تم تأكيد طلبك!" : "Order Confirmed!")</h4>

                <p class="text-muted mb-1">@(isAr ? "رقم الطلب" : "Order Number")</p>
                <div class="fw-bold fs-5 mb-3">#@Model.OrderNumber</div>

                <div class="mb-3">
                    <span class="text-muted">@(isAr ? "المبلغ الإجمالي" : "Total Amount")</span>
                    <div class="product-price fs-4 fw-bold">@Model.TotalAmount.ToString("N2") @Model.Currency</div>
                </div>

                @if (!string.IsNullOrEmpty(Model.InvoiceNumber))
                {
                    <div class="alert alert-light border mb-3 py-2 px-3" style="font-size:0.9rem;">
                        <i class="bi bi-file-earmark-text me-1 text-primary"></i>
                        @(isAr ? "رقم الفاتورة:" : "Invoice #:") <strong>@Model.InvoiceNumber</strong>
                    </div>
                }

                <p class="text-muted small mb-4">
                    @(isAr ? "سيتم التواصل معك قريباً لتأكيد التسليم." : "We will contact you shortly to confirm delivery.")
                </p>

                <div class="d-grid gap-2">
                    @if (!string.IsNullOrEmpty(Model.InvoicePdfUrl))
                    {
                        <a href="@Model.InvoicePdfUrl" target="_blank" class="btn btn-success">
                            <i class="bi bi-download me-2"></i>@(isAr ? "تحميل الفاتورة PDF" : "Download Invoice PDF")
                        </a>
                    }
                    <a href="/s/@slug" class="btn btn-primary">@(isAr ? "العودة للرئيسية" : "Back to Home")</a>
                    @if (s.IsCustomerLoggedIn)
                    {
                        <a href="/s/@slug/Customer/Orders" class="btn btn-outline-secondary">
                            @(isAr ? "طلباتي" : "My Orders")
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
