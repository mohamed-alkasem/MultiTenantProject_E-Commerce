@model CustomerRegisterViewModel
@{
    var s = Model.Store;
    bool isAr = s.IsAr;
    string slug = s.StoreSlug;
    ViewData["Title"] = isAr ? "إنشاء حساب" : "Register";
}

<div class="container page-section">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6">
            <div class="card p-1">
                <div class="card-body">
                    <h4 class="fw-bold mb-1 text-center">@(isAr ? "إنشاء حساب جديد" : "Create Account")</h4>
                    <p class="text-muted text-center small mb-4">
                        @(isAr ? "أنشئ حسابك لتتبع طلباتك" : "Create your account to track orders")
                    </p>

                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label fw-medium">@(isAr ? "الاسم الأول" : "First Name") *</label>
                                <input asp-for="FirstName" class="form-control" required autofocus />
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-medium">@(isAr ? "الاسم الأخير" : "Last Name") *</label>
                                <input asp-for="LastName" class="form-control" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium">@(isAr ? "البريد الإلكتروني" : "Email") *</label>
                                <input asp-for="Email" type="email" class="form-control" dir="ltr"
                                       placeholder="example@email.com" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium">@(isAr ? "رقم الهاتف" : "Phone")</label>
                                <input asp-for="PhoneNumber" class="form-control" dir="ltr" placeholder="+966..." />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium">@(isAr ? "كلمة المرور" : "Password") *</label>
                                <input asp-for="Password" type="password" class="form-control" required />
                                <div class="form-text">@(isAr ? "6 أحرف على الأقل، تحتوي على أرقام وحروف" : "Min 6 characters with numbers and letters")</div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium">@(isAr ? "تأكيد كلمة المرور" : "Confirm Password") *</label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" required />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 mt-4">
                            @(isAr ? "إنشاء الحساب" : "Create Account")
                        </button>
                    </form>

                    <hr />
                    <div class="text-center small">
                        @(isAr ? "لديك حساب بالفعل؟" : "Already have an account?")
                        <a href="/s/@slug/Customer/Login" class="fw-medium">
                            @(isAr ? "تسجيل الدخول" : "Login")
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
