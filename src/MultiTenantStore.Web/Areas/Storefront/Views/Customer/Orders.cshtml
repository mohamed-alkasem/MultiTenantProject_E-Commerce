@model CustomerOrdersViewModel
@{
    var s = Model.Store;
    bool isAr = s.IsAr;
    string slug = s.StoreSlug;
    ViewData["Title"] = isAr ? "طلباتي" : "My Orders";

    string OrderBadge(string st) => st switch
    {
        "Pending" => "bg-warning text-dark",
        "Processing" => "bg-info text-dark",
        "Completed" => "bg-success",
        "Cancelled" => "bg-danger",
        _ => "bg-secondary"
    };
    string OrderAr(string st) => st switch
    {
        "Pending" => "معلق", "Processing" => "قيد التنفيذ",
        "Completed" => "مكتمل", "Cancelled" => "ملغى",
        _ => st
    };
    string PaymentAr(string st) => st switch
    {
        "Pending" => "معلق", "Paid" => "مدفوع", "Failed" => "فشل",
        _ => st
    };
}

<div class="container page-section">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h4 class="fw-bold mb-1">@(isAr ? "طلباتي" : "My Orders")</h4>
            <p class="text-muted small mb-0">@Model.CustomerName</p>
        </div>
    </div>

    @if (!Model.Orders.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-bag fs-1 d-block mb-3 opacity-25"></i>
            <h5>@(isAr ? "لا توجد طلبات بعد" : "No orders yet")</h5>
            <a href="/s/@slug/Products" class="btn btn-primary mt-3">@(isAr ? "تسوق الآن" : "Shop Now")</a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>@(isAr ? "رقم الطلب" : "Order #")</th>
                                <th>@(isAr ? "الحالة" : "Status")</th>
                                <th>@(isAr ? "الدفع" : "Payment")</th>
                                <th>@(isAr ? "المبلغ" : "Amount")</th>
                                <th>@(isAr ? "التاريخ" : "Date")</th>
                                <th>@(isAr ? "الفاتورة" : "Invoice")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in Model.Orders)
                            {
                                <tr>
                                    <td class="fw-medium">#@o.OrderNumber</td>
                                    <td>
                                        <span class="badge @OrderBadge(o.Status)" style="font-size:0.75rem;">
                                            @(isAr ? OrderAr(o.Status) : o.Status)
                                        </span>
                                    </td>
                                    <td class="text-muted small">@(isAr ? PaymentAr(o.PaymentStatus) : o.PaymentStatus)</td>
                                    <td class="fw-medium">@o.TotalAmount.ToString("N2") @o.Currency</td>
                                    <td class="text-muted small">@o.CreatedAt.ToString("yyyy/MM/dd")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(o.InvoicePdfUrl))
                                        {
                                            <a href="@o.InvoicePdfUrl" target="_blank"
                                               class="btn btn-sm btn-outline-success py-0 px-2" style="font-size:0.78rem;">
                                                <i class="bi bi-download me-1"></i>PDF
                                            </a>
                                        }
                                        else if (!string.IsNullOrEmpty(o.InvoiceNumber))
                                        {
                                            <span class="text-muted small">@o.InvoiceNumber</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
