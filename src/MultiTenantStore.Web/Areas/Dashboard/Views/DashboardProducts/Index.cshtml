@model ProductListViewModel
@{
    bool isAr = (Context.Request.Cookies["dash_lang"] ?? "ar") == "ar";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="mb-0 fw-bold">@(isAr ? "المنتجات" : "Products")</h5>
        <p class="text-muted small mb-0">@(isAr ? "إدارة منتجات متجرك" : "Manage your store products")</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> @(isAr ? "منتج جديد" : "New Product")
    </a>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center gap-2">
        <form method="get" class="d-flex gap-2 flex-grow-1">
            <input type="text" name="search" value="@Model.Search"
                   class="form-control form-control-sm" placeholder="@(isAr ? "بحث عن منتج..." : "Search products...")" />
            <button type="submit" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x-circle"></i>
                </a>
            }
        </form>
        <span class="text-muted small text-nowrap">@Model.Products.Count @(isAr ? "منتج" : "products")</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Products.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-box-seam fs-1 d-block mb-2 opacity-25"></i>
                <p class="mb-0">@(string.IsNullOrEmpty(Model.Search) ? (isAr ? "لا توجد منتجات" : "No products yet") : (isAr ? "لا توجد منتجات تطابق البحث" : "No products match your search"))</p>
                @if (string.IsNullOrEmpty(Model.Search))
                {
                    <a asp-action="Create" class="btn btn-primary mt-3">@(isAr ? "إضافة أول منتج" : "Add First Product")</a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>@(isAr ? "المنتج" : "Product")</th>
                            <th>@(isAr ? "الرمز (SKU)" : "SKU")</th>
                            <th>@(isAr ? "السعر" : "Price")</th>
                            <th>@(isAr ? "المخزون" : "Stock")</th>
                            <th>@(isAr ? "الحالة" : "Status")</th>
                            <th class="text-center">@(isAr ? "إجراءات" : "Actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.Products)
                        {
                            <tr>
                                <td>
                                    <div class="fw-medium">@product.Name</div>
                                    @if (!string.IsNullOrEmpty(product.NameAr))
                                    {
                                        <div class="text-muted small">@product.NameAr</div>
                                    }
                                </td>
                                <td class="text-muted small font-monospace">@product.SKU</td>
                                <td class="fw-medium">
                                    @product.Price.ToString("N2")
                                    @if (product.CompareAtPrice.HasValue)
                                    {
                                        <small class="text-decoration-line-through text-muted ms-1">
                                            @product.CompareAtPrice.Value.ToString("N2")
                                        </small>
                                    }
                                </td>
                                <td>
                                    <span class="@(product.StockQuantity <= 0 ? "text-danger" : product.StockQuantity <= 5 ? "text-warning" : "text-success") fw-medium">
                                        @product.StockQuantity
                                    </span>
                                </td>
                                <td>
                                    @if (product.IsActive)
                                    {
                                        <span class="badge bg-success badge-status">@(isAr ? "نشط" : "Active")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary badge-status">@(isAr ? "معطّل" : "Inactive")</span>
                                    }
                                    @if (product.IsFeatured)
                                    {
                                        <span class="badge bg-warning text-dark badge-status ms-1">@(isAr ? "مميز" : "Featured")</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-action="Edit" asp-route-id="@product.Id"
                                           class="btn btn-action btn-outline-primary" title="@(isAr ? "تعديل" : "Edit")">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" action="/Dashboard/DashboardProducts/Delete/@product.Id"
                                              onsubmit="return confirm('@(isAr ? "هل أنت متأكد من حذف هذا المنتج؟" : "Delete this product?")')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-action btn-outline-danger" title="@(isAr ? "حذف" : "Delete")">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
