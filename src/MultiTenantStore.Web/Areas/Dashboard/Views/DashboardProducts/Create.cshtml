@model ProductFormViewModel

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-right"></i>
    </a>
    <div>
        <h5 class="mb-0 fw-bold">إضافة منتج جديد</h5>
    </div>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-12 col-lg-8">

            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-info-circle me-2 text-primary"></i>معلومات المنتج</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-medium">الاسم (إنجليزي) <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="Product Name" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NameAr" class="form-label fw-medium">الاسم بالعربي</label>
                            <input asp-for="NameAr" class="form-control" placeholder="اسم المنتج" dir="auto" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Slug" class="form-label fw-medium">الرابط المختصر <span class="text-danger">*</span></label>
                            <input asp-for="Slug" class="form-control" placeholder="product-slug" dir="ltr" />
                            <span asp-validation-for="Slug" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label fw-medium">الفئة <span class="text-danger">*</span></label>
                            <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                                <option value="">-- اختر الفئة --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="ShortDescription" class="form-label fw-medium">وصف مختصر</label>
                            <textarea asp-for="ShortDescription" class="form-control" rows="2" placeholder="Short Description"></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="ShortDescriptionAr" class="form-label fw-medium">وصف مختصر بالعربي</label>
                            <textarea asp-for="ShortDescriptionAr" class="form-control" rows="2" placeholder="وصف مختصر" dir="auto"></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-medium">وصف تفصيلي</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Full Description"></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="DescriptionAr" class="form-label fw-medium">وصف تفصيلي بالعربي</label>
                            <textarea asp-for="DescriptionAr" class="form-control" rows="4" placeholder="وصف تفصيلي" dir="auto"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-cash-stack me-2 text-success"></i>التسعير والمخزون</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label fw-medium">السعر <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                                <span class="input-group-text">ر.س</span>
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CompareAtPrice" class="form-label fw-medium">سعر المقارنة</label>
                            <div class="input-group">
                                <input asp-for="CompareAtPrice" class="form-control" type="number" step="0.01" min="0" />
                                <span class="input-group-text">ر.س</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CostPrice" class="form-label fw-medium">سعر التكلفة</label>
                            <div class="input-group">
                                <input asp-for="CostPrice" class="form-control" type="number" step="0.01" min="0" />
                                <span class="input-group-text">ر.س</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="SKU" class="form-label fw-medium">الرمز (SKU) <span class="text-danger">*</span></label>
                            <input asp-for="SKU" class="form-control font-monospace" placeholder="SKU-001" dir="ltr" />
                            <span asp-validation-for="SKU" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StockQuantity" class="form-label fw-medium">الكمية في المخزون</label>
                            <input asp-for="StockQuantity" class="form-control" type="number" min="0" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="LowStockThreshold" class="form-label fw-medium">حد نقص المخزون</label>
                            <input asp-for="LowStockThreshold" class="form-control" type="number" min="0" />
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="col-12 col-lg-4">
            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-toggles me-2 text-info"></i>الإعدادات</div>
                <div class="card-body">
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">منتج نشط</label>
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                        <label asp-for="IsFeatured" class="form-check-label">منتج مميز</label>
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="TrackInventory" class="form-check-input" type="checkbox" />
                        <label asp-for="TrackInventory" class="form-check-label">تتبع المخزون</label>
                    </div>
                    <div class="mb-0">
                        <label asp-for="SortOrder" class="form-label fw-medium">ترتيب العرض</label>
                        <input asp-for="SortOrder" class="form-control" type="number" min="0" />
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle me-1"></i> حفظ المنتج
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
            </div>
        </div>
    </div>
</form>
