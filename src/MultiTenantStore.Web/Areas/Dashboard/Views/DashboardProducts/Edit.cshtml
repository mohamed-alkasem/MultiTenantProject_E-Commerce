@model ProductFormViewModel
@{
    bool isAr = (Context.Request.Cookies["dash_lang"] ?? "ar") == "ar";
}

@* Secondary forms placed OUTSIDE the main edit form — avoids nested-form antiforgery failure *@
@foreach (var img in Model.Images.OrderByDescending(x => x.IsPrimary).ThenBy(x => x.SortOrder))
{
    @if (!img.IsPrimary)
    {
        <form id="setPrimary_@img.Id" method="post" action="/Dashboard/DashboardProducts/SetPrimaryImage/@Model.Id">
            @Html.AntiForgeryToken()
            <input type="hidden" name="imageId" value="@img.Id" />
        </form>
    }
    <form id="deleteImg_@img.Id" method="post" action="/Dashboard/DashboardProducts/DeleteImage/@Model.Id"
          onsubmit="return confirm('@(isAr ? "حذف الصورة؟" : "Delete image?")')">
        @Html.AntiForgeryToken()
        <input type="hidden" name="imageId" value="@img.Id" />
    </form>
}

<form id="uploadImgForm" method="post" action="/Dashboard/DashboardProducts/UploadImage/@Model.Id" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
</form>

<form id="deleteProductForm" method="post" action="/Dashboard/DashboardProducts/Delete/@Model.Id"
      onsubmit="return confirm('@(isAr ? "هل أنت متأكد من حذف هذا المنتج؟" : "Delete this product?")')">
    @Html.AntiForgeryToken()
</form>

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-right"></i>
    </a>
    <div>
        <h5 class="mb-0 fw-bold">@(isAr ? "تعديل المنتج" : "Edit Product")</h5>
    </div>
</div>

<form method="post" action="/Dashboard/DashboardProducts/Edit/@Model.Id">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-12 col-lg-8">

            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-info-circle me-2 text-primary"></i>@(isAr ? "معلومات المنتج" : "Product Information")</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-medium">@(isAr ? "الاسم (إنجليزي)" : "Name (English)") <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NameAr" class="form-label fw-medium">@(isAr ? "الاسم بالعربي" : "Name (Arabic)")</label>
                            <input asp-for="NameAr" class="form-control" dir="auto" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Slug" class="form-label fw-medium">@(isAr ? "الرابط المختصر" : "URL Slug") <span class="text-danger">*</span></label>
                            <input asp-for="Slug" class="form-control" dir="ltr" />
                            <span asp-validation-for="Slug" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label fw-medium">@(isAr ? "الفئة" : "Category") <span class="text-danger">*</span></label>
                            <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                                <option value="">@(isAr ? "-- اختر الفئة --" : "-- Select Category --")</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="ShortDescription" class="form-label fw-medium">@(isAr ? "وصف مختصر" : "Short Description")</label>
                            <textarea asp-for="ShortDescription" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="ShortDescriptionAr" class="form-label fw-medium">@(isAr ? "وصف مختصر بالعربي" : "Short Description (Arabic)")</label>
                            <textarea asp-for="ShortDescriptionAr" class="form-control" rows="2" dir="auto"></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-medium">@(isAr ? "وصف تفصيلي" : "Full Description")</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="DescriptionAr" class="form-label fw-medium">@(isAr ? "وصف تفصيلي بالعربي" : "Full Description (Arabic)")</label>
                            <textarea asp-for="DescriptionAr" class="form-control" rows="4" dir="auto"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-cash-stack me-2 text-success"></i>@(isAr ? "التسعير والمخزون" : "Pricing & Inventory")</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label fw-medium">@(isAr ? "السعر" : "Price") <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                                <span class="input-group-text">@(isAr ? "ر.س" : "SAR")</span>
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CompareAtPrice" class="form-label fw-medium">@(isAr ? "سعر المقارنة" : "Compare At Price")</label>
                            <div class="input-group">
                                <input asp-for="CompareAtPrice" class="form-control" type="number" step="0.01" min="0" />
                                <span class="input-group-text">@(isAr ? "ر.س" : "SAR")</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CostPrice" class="form-label fw-medium">@(isAr ? "سعر التكلفة" : "Cost Price")</label>
                            <div class="input-group">
                                <input asp-for="CostPrice" class="form-control" type="number" step="0.01" min="0" />
                                <span class="input-group-text">@(isAr ? "ر.س" : "SAR")</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="SKU" class="form-label fw-medium">@(isAr ? "الرمز (SKU)" : "SKU") <span class="text-danger">*</span></label>
                            <input asp-for="SKU" class="form-control font-monospace" dir="ltr" />
                            <span asp-validation-for="SKU" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StockQuantity" class="form-label fw-medium">@(isAr ? "الكمية في المخزون" : "Stock Quantity")</label>
                            <input asp-for="StockQuantity" class="form-control" type="number" min="0" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="LowStockThreshold" class="form-label fw-medium">@(isAr ? "حد نقص المخزون" : "Low Stock Threshold")</label>
                            <input asp-for="LowStockThreshold" class="form-control" type="number" min="0" />
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="col-12 col-lg-4">

            <div class="card mb-3">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <span><i class="bi bi-images me-2 text-warning"></i>@(isAr ? "صور المنتج" : "Product Images")</span>
                    <span class="badge bg-secondary">@Model.Images.Count</span>
                </div>
                <div class="card-body">
                    @if (Model.Images.Any())
                    {
                        <div class="row g-2 mb-3">
                            @foreach (var img in Model.Images.OrderByDescending(x => x.IsPrimary).ThenBy(x => x.SortOrder))
                            {
                                <div class="col-6">
                                    <div class="position-relative border rounded overflow-hidden" style="height:100px;">
                                        <img src="@img.ImageUrl" alt="@img.AltText" class="w-100 h-100" style="object-fit:cover;" />
                                        @if (img.IsPrimary)
                                        {
                                            <span class="position-absolute top-0 start-0 badge bg-primary m-1" style="font-size:0.6rem;">@(isAr ? "رئيسية" : "Main")</span>
                                        }
                                        <div class="position-absolute bottom-0 start-0 end-0 d-flex gap-1 p-1" style="background:rgba(0,0,0,0.5);">
                                            @if (!img.IsPrimary)
                                            {
                                                <button type="submit" form="setPrimary_@img.Id"
                                                        class="btn btn-xs btn-warning flex-fill" style="font-size:0.65rem;padding:2px 4px;"
                                                        title="@(isAr ? "تعيين رئيسية" : "Set Main")">
                                                    <i class="bi bi-star-fill"></i>
                                                </button>
                                            }
                                            <button type="submit" form="deleteImg_@img.Id"
                                                    class="btn btn-xs btn-danger flex-fill" style="font-size:0.65rem;padding:2px 4px;"
                                                    title="@(isAr ? "حذف" : "Delete")">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small text-center mb-3"><i class="bi bi-image me-1"></i>@(isAr ? "لا توجد صور بعد" : "No images yet")</p>
                    }

                    <div class="mb-2">
                        <label class="form-label fw-medium small">@(isAr ? "رفع صورة جديدة" : "Upload New Image")</label>
                        <input type="file" name="imageFile" form="uploadImgForm" class="form-control form-control-sm" accept=".jpg,.jpeg,.png,.webp" required />
                        <div class="form-text">JPG, PNG, WEBP — @(isAr ? "بحد أقصى 5 ميجا" : "max 5 MB")</div>
                    </div>
                    <div class="mb-2 form-check">
                        <input type="checkbox" name="isPrimary" value="true" form="uploadImgForm" class="form-check-input" id="isPrimary" />
                        <label class="form-check-label small" for="isPrimary">@(isAr ? "صورة رئيسية" : "Main image")</label>
                    </div>
                    <button type="submit" form="uploadImgForm" class="btn btn-sm btn-outline-warning w-100">
                        <i class="bi bi-upload me-1"></i>@(isAr ? "رفع الصورة" : "Upload")
                    </button>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-toggles me-2 text-info"></i>@(isAr ? "الإعدادات" : "Settings")</div>
                <div class="card-body">
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">@(isAr ? "منتج نشط" : "Active")</label>
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                        <label asp-for="IsFeatured" class="form-check-label">@(isAr ? "منتج مميز" : "Featured")</label>
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="TrackInventory" class="form-check-input" type="checkbox" />
                        <label asp-for="TrackInventory" class="form-check-label">@(isAr ? "تتبع المخزون" : "Track Inventory")</label>
                    </div>
                    <div class="mb-0">
                        <label asp-for="SortOrder" class="form-label fw-medium">@(isAr ? "ترتيب العرض" : "Sort Order")</label>
                        <input asp-for="SortOrder" class="form-control" type="number" min="0" />
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle me-1"></i> @(isAr ? "حفظ التعديلات" : "Save Changes")
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">@(isAr ? "إلغاء" : "Cancel")</a>
                <button type="submit" form="deleteProductForm" class="btn btn-outline-danger w-100">
                    <i class="bi bi-trash me-1"></i> @(isAr ? "حذف المنتج" : "Delete Product")
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
}
