@model List<InvoiceListDto>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="mb-0 fw-bold">الفواتير</h5>
        <p class="text-muted small mb-0">@Model.Count فاتورة</p>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-receipt-cutoff fs-1 d-block mb-2 opacity-25"></i>
                <p class="mb-0">لا توجد فواتير حتى الآن</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>رقم الفاتورة</th>
                            <th>العميل</th>
                            <th>الحالة</th>
                            <th>المبلغ</th>
                            <th>تاريخ الإصدار</th>
                            <th>PDF</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var invoice in Model)
                        {
                            <tr>
                                <td class="fw-medium">#@invoice.InvoiceNumber</td>
                                <td>@invoice.CustomerNameSnapshot</td>
                                <td>
                                    @{
                                        var (cls, ar) = invoice.Status switch
                                        {
                                            "Draft" => ("bg-secondary", "مسودة"),
                                            "Issued" => ("bg-primary", "صادرة"),
                                            "Paid" => ("bg-success", "مدفوعة"),
                                            "Cancelled" => ("bg-danger", "ملغاة"),
                                            _ => ("bg-secondary", invoice.Status)
                                        };
                                    }
                                    <span class="badge badge-status @cls">@ar</span>
                                </td>
                                <td class="fw-medium">@invoice.TotalAmount.ToString("N2") @invoice.Currency</td>
                                <td class="text-muted small">@invoice.IssueDate.ToString("yyyy/MM/dd")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(invoice.PdfUrl))
                                    {
                                        <a href="@invoice.PdfUrl" target="_blank" class="btn btn-action btn-outline-info" title="فتح PDF">
                                            <i class="bi bi-file-pdf"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@invoice.Id"
                                       class="btn btn-action btn-outline-secondary" title="التفاصيل">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
