@model CategoryFormViewModel
@{
    bool isAr = (Context.Request.Cookies["dash_lang"] ?? "ar") == "ar";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-right"></i>
    </a>
    <h5 class="mb-0 fw-bold">@(isAr ? "إضافة فئة جديدة" : "Add New Category")</h5>
</div>

<div class="row">
    <div class="col-12 col-md-7 col-lg-6">
        <div class="card">
            <div class="card-body">
                <form method="post" action="/Dashboard/DashboardCategories/Create">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-medium">@(isAr ? "الاسم (إنجليزي)" : "Name (English)") <span class="text-danger">*</span></label>
                        <input asp-for="Name" id="nameInput" class="form-control" placeholder="Category Name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NameAr" class="form-label fw-medium">@(isAr ? "الاسم بالعربي" : "Name (Arabic)")</label>
                        <input asp-for="NameAr" class="form-control" placeholder="اسم الفئة" dir="auto" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Slug" class="form-label fw-medium">@(isAr ? "الرابط المختصر" : "URL Slug") <span class="text-danger">*</span></label>
                        <input asp-for="Slug" id="slugInput" class="form-control" placeholder="category-slug" dir="ltr" />
                        <div class="form-text">@(isAr ? "يُولَّد تلقائياً من الاسم الإنجليزي" : "Auto-generated from the English name")</div>
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ParentCategoryId" class="form-label fw-medium">@(isAr ? "الفئة الأم (اختياري)" : "Parent Category (optional)")</label>
                        <select asp-for="ParentCategoryId" asp-items="Model.ParentCategories" class="form-select">
                            <option value="">@(isAr ? "-- فئة رئيسية --" : "-- Root Category --")</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SortOrder" class="form-label fw-medium">@(isAr ? "ترتيب العرض" : "Sort Order")</label>
                        <input asp-for="SortOrder" class="form-control" type="number" min="0" />
                    </div>

                    <div class="mb-4 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">@(isAr ? "فئة نشطة" : "Active")</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i> @(isAr ? "حفظ الفئة" : "Save Category")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@(isAr ? "إلغاء" : "Cancel")</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var nameEl = document.getElementById('nameInput');
    var slugEl = document.getElementById('slugInput');
    var slugManual = slugEl && slugEl.value.length > 0;
    if (slugEl) {
        slugEl.addEventListener('input', function () { slugManual = true; });
    }
    if (nameEl && slugEl) {
        nameEl.addEventListener('input', function () {
            if (slugManual) return;
            slugEl.value = nameEl.value.toLowerCase()
                .replace(/\s+/g, '-')
                .replace(/[^a-z0-9-]/g, '')
                .replace(/-+/g, '-')
                .replace(/^-+|-+$/g, '');
        });
    }
})();
</script>
<partial name="_ValidationScriptsPartial" />
}
