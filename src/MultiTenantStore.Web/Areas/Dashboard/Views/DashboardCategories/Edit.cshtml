@model CategoryFormViewModel
@{
    bool isAr = (Context.Request.Cookies["dash_lang"] ?? "ar") == "ar";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-right"></i>
    </a>
    <h5 class="mb-0 fw-bold">@(isAr ? "تعديل الفئة" : "Edit Category")</h5>
</div>

<div class="row">
    <div class="col-12 col-md-7 col-lg-6">
        <div class="card">
            <div class="card-body">
                <form method="post" action="/Dashboard/DashboardCategories/Edit/@Model.Id">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-medium">@(isAr ? "الاسم (إنجليزي)" : "Name (English)") <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NameAr" class="form-label fw-medium">@(isAr ? "الاسم بالعربي" : "Name (Arabic)")</label>
                        <input asp-for="NameAr" class="form-control" dir="auto" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Slug" class="form-label fw-medium">@(isAr ? "الرابط المختصر" : "URL Slug") <span class="text-danger">*</span></label>
                        <input asp-for="Slug" class="form-control" dir="ltr" />
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ParentCategoryId" class="form-label fw-medium">@(isAr ? "الفئة الأم" : "Parent Category")</label>
                        <select asp-for="ParentCategoryId" asp-items="Model.ParentCategories" class="form-select">
                            <option value="">@(isAr ? "-- فئة رئيسية --" : "-- Root Category --")</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SortOrder" class="form-label fw-medium">@(isAr ? "ترتيب العرض" : "Sort Order")</label>
                        <input asp-for="SortOrder" class="form-control" type="number" min="0" />
                    </div>

                    <div class="mb-4 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">@(isAr ? "فئة نشطة" : "Active")</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i> @(isAr ? "حفظ التعديلات" : "Save Changes")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@(isAr ? "إلغاء" : "Cancel")</a>
                        <form method="post" action="/Dashboard/DashboardCategories/Delete/@Model.Id"
                              onsubmit="return confirm('@(isAr ? "هل أنت متأكد من حذف هذه الفئة؟" : "Delete this category?")')"
                              class="me-auto">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="bi bi-trash me-1"></i> @(isAr ? "حذف" : "Delete")
                            </button>
                        </form>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
}
