@model ProductListViewModel

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="mb-0 fw-bold">المنتجات</h5>
        <p class="text-muted small mb-0">إدارة منتجات متجرك</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> منتج جديد
    </a>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center gap-2">
        <form method="get" class="d-flex gap-2 flex-grow-1">
            <input type="text" name="search" value="@Model.Search"
                   class="form-control form-control-sm" placeholder="بحث عن منتج..." />
            <button type="submit" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x-circle"></i>
                </a>
            }
        </form>
        <span class="text-muted small text-nowrap">@Model.Products.Count منتج</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Products.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-box-seam fs-1 d-block mb-2 opacity-25"></i>
                <p class="mb-0">لا توجد منتجات@(string.IsNullOrEmpty(Model.Search) ? "" : " تطابق البحث")</p>
                @if (string.IsNullOrEmpty(Model.Search))
                {
                    <a asp-action="Create" class="btn btn-primary mt-3">إضافة أول منتج</a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>المنتج</th>
                            <th>الرمز (SKU)</th>
                            <th>السعر</th>
                            <th>المخزون</th>
                            <th>الحالة</th>
                            <th class="text-center">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.Products)
                        {
                            <tr>
                                <td>
                                    <div class="fw-medium">@product.Name</div>
                                    @if (!string.IsNullOrEmpty(product.NameAr))
                                    {
                                        <div class="text-muted small">@product.NameAr</div>
                                    }
                                </td>
                                <td class="text-muted small font-monospace">@product.SKU</td>
                                <td class="fw-medium">
                                    @product.Price.ToString("N2")
                                    @if (product.CompareAtPrice.HasValue)
                                    {
                                        <small class="text-decoration-line-through text-muted ms-1">
                                            @product.CompareAtPrice.Value.ToString("N2")
                                        </small>
                                    }
                                </td>
                                <td>
                                    <span class="@(product.StockQuantity <= 0 ? "text-danger" : product.StockQuantity <= 5 ? "text-warning" : "text-success") fw-medium">
                                        @product.StockQuantity
                                    </span>
                                </td>
                                <td>
                                    @if (product.IsActive)
                                    {
                                        <span class="badge bg-success badge-status">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary badge-status">معطّل</span>
                                    }
                                    @if (product.IsFeatured)
                                    {
                                        <span class="badge bg-warning text-dark badge-status ms-1">مميز</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-action="Edit" asp-route-id="@product.Id"
                                           class="btn btn-action btn-outline-primary" title="تعديل">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@product.Id" method="post"
                                              onsubmit="return confirm('هل أنت متأكد من حذف هذا المنتج؟')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-action btn-outline-danger" title="حذف">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
