@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "تسجيل الدخول";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل الدخول - لوحة التحكم</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&display=swap" />
    <style>
        * { font-family: 'Tajawal', sans-serif; }
        body {
            background: linear-gradient(135deg, #1a2332 0%, #2d5986 50%, #1a6b3a 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        .login-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }
        .login-icon {
            width: 64px; height: 64px;
            background: linear-gradient(135deg, #3498db, #2ecc71);
            border-radius: 16px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.75rem; color: white; margin: 0 auto;
        }
        .form-control:focus { border-color: #3498db; box-shadow: 0 0 0 0.2rem rgba(52,152,219,0.2); }
        .btn-primary { background: linear-gradient(135deg, #3498db, #2980b9); border: none; }
        .btn-primary:hover { background: linear-gradient(135deg, #2980b9, #2471a3); }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-sm-10 col-md-7 col-lg-5 col-xl-4">
                <div class="card login-card">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="login-icon mb-3">
                                <i class="bi bi-shop"></i>
                            </div>
                            <h4 class="fw-bold mb-1">لوحة التحكم</h4>
                            <p class="text-muted small">سجّل دخولك لإدارة متجرك</p>
                        </div>

                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                        {
                            <div class="alert alert-danger py-2" role="alert">
                                <i class="bi bi-exclamation-circle-fill me-1"></i>
                                <span asp-validation-summary="All"></span>
                            </div>
                        }

                        <form asp-action="Login" method="post">
                            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-medium">البريد الإلكتروني</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-envelope text-muted"></i>
                                    </span>
                                    <input asp-for="Email" class="form-control border-start-0 ps-0"
                                           placeholder="example@store.com" autocomplete="email" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-medium">كلمة المرور</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-lock text-muted"></i>
                                    </span>
                                    <input asp-for="Password" class="form-control border-start-0 ps-0"
                                           placeholder="••••••••" autocomplete="current-password" />
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-4 form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label text-muted small">تذكرني</label>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-2 fw-medium">
                                <i class="bi bi-box-arrow-in-left me-1"></i> دخول
                            </button>
                        </form>
                    </div>
                </div>
                <p class="text-center text-white-50 mt-3 small">
                    &copy; @DateTime.Now.Year متجري - جميع الحقوق محفوظة
                </p>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
