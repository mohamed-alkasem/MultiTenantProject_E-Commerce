@model OrdersListViewModel

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="mb-0 fw-bold">الطلبات</h5>
        <p class="text-muted small mb-0">إجمالي @Model.TotalCount طلب</p>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-sm-6 col-md-4">
                <input type="text" name="search" value="@Model.Search"
                       class="form-control form-control-sm" placeholder="بحث برقم الطلب أو العميل..." />
            </div>
            <div class="col-sm-4 col-md-3">
                <select name="status" class="form-select form-select-sm">
                    <option value="">كل الحالات</option>
                    <option value="Pending" selected="@(Model.StatusFilter == "Pending")">معلق</option>
                    <option value="Processing" selected="@(Model.StatusFilter == "Processing")">قيد التنفيذ</option>
                    <option value="Completed" selected="@(Model.StatusFilter == "Completed")">مكتمل</option>
                    <option value="Cancelled" selected="@(Model.StatusFilter == "Cancelled")">ملغى</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-search"></i> بحث
                </button>
                @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.StatusFilter))
                {
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary ms-1">
                        <i class="bi bi-x-circle"></i>
                    </a>
                }
            </div>
        </form>
    </div>
    <div class="card-body p-0">
        @if (!Model.Orders.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-bag fs-1 d-block mb-2 opacity-25"></i>
                <p class="mb-0">لا توجد طلبات</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>رقم الطلب</th>
                            <th>العميل</th>
                            <th>حالة الطلب</th>
                            <th>حالة الدفع</th>
                            <th>الشحن</th>
                            <th>المبلغ</th>
                            <th>التاريخ</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            <tr>
                                <td class="fw-medium">#@order.OrderNumber</td>
                                <td>@(order.CustomerName ?? "—")</td>
                                <td>
                                    @{
                                        var (sCls, sAr) = order.Status switch
                                        {
                                            "Pending" => ("bg-warning text-dark", "معلق"),
                                            "Processing" => ("bg-info text-dark", "قيد التنفيذ"),
                                            "Completed" => ("bg-success", "مكتمل"),
                                            "Cancelled" => ("bg-danger", "ملغى"),
                                            _ => ("bg-secondary", order.Status)
                                        };
                                    }
                                    <span class="badge badge-status @sCls">@sAr</span>
                                </td>
                                <td>
                                    @{
                                        var (pCls, pAr) = order.PaymentStatus switch
                                        {
                                            "Pending" => ("bg-warning text-dark", "غير مدفوع"),
                                            "Paid" => ("bg-success", "مدفوع"),
                                            "Refunded" => ("bg-info text-dark", "مُسترد"),
                                            "Failed" => ("bg-danger", "فشل"),
                                            _ => ("bg-secondary", order.PaymentStatus)
                                        };
                                    }
                                    <span class="badge badge-status @pCls">@pAr</span>
                                </td>
                                <td>
                                    @{
                                        var shAr = order.ShippingStatus switch
                                        {
                                            "Pending" => "لم يُشحن",
                                            "Processing" => "جاري الشحن",
                                            "Shipped" => "تم الشحن",
                                            "Delivered" => "تم التوصيل",
                                            "Returned" => "مُعاد",
                                            _ => order.ShippingStatus
                                        };
                                    }
                                    <span class="text-muted small">@shAr</span>
                                </td>
                                <td class="fw-medium">@order.TotalAmount.ToString("N2") @order.Currency</td>
                                <td class="text-muted small">@order.CreatedAt.ToString("yyyy/MM/dd")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@order.Id"
                                       class="btn btn-action btn-outline-secondary" title="التفاصيل">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalCount > Model.PageSize)
            {
                <div class="d-flex justify-content-center py-3">
                    <nav>
                        <ul class="pagination pagination-sm">
                            @if (Model.PageNumber > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-page="@(Model.PageNumber - 1)"
                                       asp-route-search="@Model.Search"
                                       asp-route-status="@Model.StatusFilter">السابق</a>
                                </li>
                            }
                            <li class="page-item active">
                                <span class="page-link">@Model.PageNumber</span>
                            </li>
                            @if (Model.PageNumber * Model.PageSize < Model.TotalCount)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-page="@(Model.PageNumber + 1)"
                                       asp-route-search="@Model.Search"
                                       asp-route-status="@Model.StatusFilter">التالي</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>
