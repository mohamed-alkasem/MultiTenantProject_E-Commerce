@model OrdersListViewModel
@{
    bool isAr = (Context.Request.Cookies["dash_lang"] ?? "ar") == "ar";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="mb-0 fw-bold">@(isAr ? "الطلبات" : "Orders")</h5>
        <p class="text-muted small mb-0">@Model.TotalCount @(isAr ? "طلب إجمالاً" : "orders total")</p>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-sm-6 col-md-4">
                <input type="text" name="search" value="@Model.Search"
                       class="form-control form-control-sm" placeholder="@(isAr ? "بحث برقم الطلب أو العميل..." : "Search by order# or customer...")" />
            </div>
            <div class="col-sm-4 col-md-3">
                <select name="status" class="form-select form-select-sm">
                    <option value="">@(isAr ? "كل الحالات" : "All Statuses")</option>
                    <option value="Pending"    selected="@(Model.StatusFilter == "Pending")">@(isAr    ? "معلق"         : "Pending")</option>
                    <option value="Confirmed"  selected="@(Model.StatusFilter == "Confirmed")">@(isAr  ? "مؤكد"          : "Confirmed")</option>
                    <option value="Processing" selected="@(Model.StatusFilter == "Processing")">@(isAr ? "قيد التنفيذ"  : "Processing")</option>
                    <option value="Completed"  selected="@(Model.StatusFilter == "Completed")">@(isAr  ? "مكتمل"        : "Completed")</option>
                    <option value="Cancelled"  selected="@(Model.StatusFilter == "Cancelled")">@(isAr  ? "ملغى"          : "Cancelled")</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-search"></i> @(isAr ? "بحث" : "Search")
                </button>
                @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.StatusFilter))
                {
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary ms-1">
                        <i class="bi bi-x-circle"></i>
                    </a>
                }
            </div>
        </form>
    </div>
    <div class="card-body p-0">
        @if (!Model.Orders.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-bag fs-1 d-block mb-2 opacity-25"></i>
                <p class="mb-0">@(isAr ? "لا توجد طلبات" : "No orders found")</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>@(isAr ? "رقم الطلب" : "Order #")</th>
                            <th>@(isAr ? "العميل" : "Customer")</th>
                            <th>@(isAr ? "حالة الطلب" : "Order Status")</th>
                            <th>@(isAr ? "حالة الدفع" : "Payment")</th>
                            <th>@(isAr ? "الشحن" : "Shipping")</th>
                            <th>@(isAr ? "المبلغ" : "Amount")</th>
                            <th>@(isAr ? "التاريخ" : "Date")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            <tr>
                                <td class="fw-medium">#@order.OrderNumber</td>
                                <td>@(order.CustomerName ?? "—")</td>
                                <td>
                                    @{
                                        var (sCls, sLabel) = order.Status switch
                                        {
                                            "Pending"    => ("bg-warning text-dark", isAr ? "معلق"        : "Pending"),
                                            "Confirmed"  => ("bg-info text-dark",    isAr ? "مؤكد"         : "Confirmed"),
                                            "Processing" => ("bg-info text-dark",    isAr ? "قيد التنفيذ" : "Processing"),
                                            "Completed"  => ("bg-success",           isAr ? "مكتمل"       : "Completed"),
                                            "Cancelled"  => ("bg-danger",            isAr ? "ملغى"         : "Cancelled"),
                                            _            => ("bg-secondary",          order.Status)
                                        };
                                    }
                                    <span class="badge badge-status @sCls">@sLabel</span>
                                </td>
                                <td>
                                    @{
                                        var (pCls, pLabel) = order.PaymentStatus switch
                                        {
                                            "Pending"           => ("bg-warning text-dark", isAr ? "غير مدفوع"       : "Unpaid"),
                                            "Paid"              => ("bg-success",           isAr ? "مدفوع"           : "Paid"),
                                            "Refunded"          => ("bg-info text-dark",    isAr ? "مُسترد"          : "Refunded"),
                                            "PartiallyRefunded" => ("bg-info text-dark",    isAr ? "مسترد جزئياً"   : "Partial Refund"),
                                            "Failed"            => ("bg-danger",            isAr ? "فشل"             : "Failed"),
                                            _                   => ("bg-secondary",          order.PaymentStatus)
                                        };
                                    }
                                    <span class="badge badge-status @pCls">@pLabel</span>
                                </td>
                                <td>
                                    @{
                                        var shLabel = order.ShippingStatus switch
                                        {
                                            "NotShipped" => isAr ? "لم يُشحن"     : "Not Shipped",
                                            "Processing" => isAr ? "جاري التجهيز" : "Preparing",
                                            "Shipped"    => isAr ? "تم الشحن"     : "Shipped",
                                            "Delivered"  => isAr ? "تم التوصيل"   : "Delivered",
                                            "Cancelled"  => isAr ? "ملغى"          : "Cancelled",
                                            "Returned"   => isAr ? "مُعاد"         : "Returned",
                                            _            => order.ShippingStatus
                                        };
                                    }
                                    <span class="text-muted small">@shLabel</span>
                                </td>
                                <td class="fw-medium">@order.TotalAmount.ToString("N2") @order.Currency</td>
                                <td class="text-muted small">@order.CreatedAt.ToString("yyyy/MM/dd")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@order.Id"
                                       class="btn btn-action btn-outline-secondary" title="@(isAr ? "التفاصيل" : "Details")">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalCount > Model.PageSize)
            {
                <div class="d-flex justify-content-center py-3">
                    <nav>
                        <ul class="pagination pagination-sm">
                            @if (Model.PageNumber > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-page="@(Model.PageNumber - 1)"
                                       asp-route-search="@Model.Search"
                                       asp-route-status="@Model.StatusFilter">@(isAr ? "السابق" : "Prev")</a>
                                </li>
                            }
                            <li class="page-item active">
                                <span class="page-link">@Model.PageNumber</span>
                            </li>
                            @if (Model.PageNumber * Model.PageSize < Model.TotalCount)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-page="@(Model.PageNumber + 1)"
                                       asp-route-search="@Model.Search"
                                       asp-route-status="@Model.StatusFilter">@(isAr ? "التالي" : "Next")</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>
