@model PlatformPlanFormViewModel
@{
    string lang = Context.Request.Cookies["admin_lang"] ?? "ar";
    bool isAr = lang == "ar";
    bool isEdit = Model.Id.HasValue;
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card" style="border-radius:14px;">
            <div class="card-header border-bottom py-3">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-layers me-2 text-primary"></i>
                    @(isEdit ? (isAr ? "تعديل الخطة" : "Edit Plan") : (isAr ? "إضافة خطة جديدة" : "Add New Plan"))
                </h6>
            </div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger py-2 mb-3">
                        <i class="bi bi-exclamation-circle-fill me-1"></i>
                        <span asp-validation-summary="All" class="d-inline"></span>
                    </div>
                }

                <form asp-area="PlatformAdmin" asp-controller="PlatformPlans" asp-action="Save" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label asp-for="Code" class="form-label fw-medium small">
                                @(isAr ? "الكود (Code)" : "Code")
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Code" class="form-control font-monospace text-uppercase"
                                   placeholder="FREE / BASIC / PRO" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Name" class="form-label fw-medium small">
                                @(isAr ? "الاسم (English)" : "Name (English)")
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Name" class="form-control" placeholder="Basic" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="NameAr" class="form-label fw-medium small">
                                @(isAr ? "الاسم بالعربية" : "Name (Arabic)")
                            </label>
                            <input asp-for="NameAr" class="form-control" placeholder="أساسي" />
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="PriceMonthly" class="form-label fw-medium small">
                                @(isAr ? "السعر الشهري ($)" : "Monthly Price ($)")
                            </label>
                            <input asp-for="PriceMonthly" class="form-control" type="number"
                                   min="0" step="0.01" placeholder="0.00" />
                            <span asp-validation-for="PriceMonthly" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PriceYearly" class="form-label fw-medium small">
                                @(isAr ? "السعر السنوي ($)" : "Yearly Price ($)")
                            </label>
                            <input asp-for="PriceYearly" class="form-control" type="number"
                                   min="0" step="0.01" placeholder="0.00" />
                            <span asp-validation-for="PriceYearly" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="MaxProducts" class="form-label fw-medium small">
                                @(isAr ? "الحد الأقصى للمنتجات" : "Max Products")
                            </label>
                            <input asp-for="MaxProducts" class="form-control" type="number" min="0" />
                            <span asp-validation-for="MaxProducts" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MaxStaffUsers" class="form-label fw-medium small">
                                @(isAr ? "الحد الأقصى للموظفين" : "Max Staff Users")
                            </label>
                            <input asp-for="MaxStaffUsers" class="form-control" type="number" min="0" />
                            <span asp-validation-for="MaxStaffUsers" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input asp-for="IsActive" class="form-check-input" role="switch" />
                        <label asp-for="IsActive" class="form-check-label fw-medium small">
                            @(isAr ? "الخطة نشطة (تظهر للتجار عند التسجيل)" : "Plan is Active (visible to merchants during registration)")
                        </label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i>
                            @(isAr ? "حفظ الخطة" : "Save Plan")
                        </button>
                        <a asp-area="PlatformAdmin" asp-controller="PlatformPlans" asp-action="Index"
                           class="btn btn-outline-secondary">
                            @(isAr ? "إلغاء" : "Cancel")
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
