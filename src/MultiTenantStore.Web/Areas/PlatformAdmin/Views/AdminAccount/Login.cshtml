@model AdminLoginViewModel
@{
    Layout = null;
    string lang = Context.Request.Cookies["admin_lang"] ?? "ar";
    bool isAr = lang == "ar";
    string dir = isAr ? "rtl" : "ltr";
    string bootstrapCss = isAr
        ? "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css"
        : "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css";
    ViewData["Title"] = isAr ? "تسجيل الدخول" : "Sign In";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(isAr ? "إدارة المنصة — تسجيل الدخول" : "Platform Admin — Sign In")</title>
    <link rel="stylesheet" href="@bootstrapCss" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&display=swap" />
    <style>
        * { font-family: 'Tajawal', sans-serif; }
        body {
            background: linear-gradient(135deg, #1a1f36 0%, #2c3154 60%, #1a1f36 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        .login-card { border: none; border-radius: 16px; box-shadow: 0 24px 60px rgba(0,0,0,0.35); }
        .brand-icon {
            width: 64px; height: 64px;
            background: linear-gradient(135deg, #6c63ff, #3ecf8e);
            border-radius: 16px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.75rem; color: white; margin: 0 auto;
        }
        .form-control:focus { border-color: #6c63ff; box-shadow: 0 0 0 0.2rem rgba(108,99,255,0.2); }
        .btn-primary { background: linear-gradient(135deg, #6c63ff, #5a52d5); border: none; }
        .btn-primary:hover { background: linear-gradient(135deg, #5a52d5, #4a43c1); }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-sm-10 col-md-7 col-lg-5 col-xl-4">

                <div class="card login-card">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="brand-icon mb-3">
                                <i class="bi bi-shield-lock-fill"></i>
                            </div>
                            <h4 class="fw-bold mb-1">@(isAr ? "إدارة المنصة" : "Platform Admin")</h4>
                            <p class="text-muted small">@(isAr ? "الوصول مقيد على المدراء فقط" : "Restricted to authorized admins only")</p>
                        </div>

                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                        {
                            <div class="alert alert-danger py-2" role="alert">
                                <i class="bi bi-exclamation-circle-fill me-1"></i>
                                <span asp-validation-summary="All"></span>
                            </div>
                        }

                        <form asp-action="Login" method="post">
                            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-medium">
                                    @(isAr ? "البريد الإلكتروني" : "Email Address")
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-envelope text-muted"></i>
                                    </span>
                                    <input asp-for="Email" class="form-control border-start-0 ps-0"
                                           placeholder="admin@example.com" autocomplete="email" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-medium">
                                    @(isAr ? "كلمة المرور" : "Password")
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-lock text-muted"></i>
                                    </span>
                                    <input asp-for="Password" class="form-control border-start-0 ps-0"
                                           placeholder="••••••••" autocomplete="current-password" />
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-4 form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label text-muted small">
                                    @(isAr ? "تذكرني" : "Remember me")
                                </label>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-2 fw-medium">
                                <i class="bi bi-shield-check me-1"></i>
                                @(isAr ? "دخول آمن" : "Secure Sign In")
                            </button>
                        </form>

                        <div class="text-center mt-3">
                            <form asp-area="PlatformAdmin" asp-controller="AdminAccount" asp-action="SetLanguage" method="post">
                                <input type="hidden" name="lang" value="@(isAr ? "en" : "ar")" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-link text-muted text-decoration-none">
                                    @(isAr ? "English" : "عربي")
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <p class="text-center text-white-50 mt-3 small">
                    &copy; @DateTime.Now.Year MultiTenantStore &mdash; @(isAr ? "إدارة المنصة" : "Platform Admin")
                </p>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
