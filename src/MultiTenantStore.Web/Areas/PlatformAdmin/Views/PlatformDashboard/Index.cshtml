@model PlatformDashboardViewModel
@{
    string lang = Context.Request.Cookies["admin_lang"] ?? "ar";
    bool isAr = lang == "ar";
    ViewData["Title"] = isAr ? "لوحة التحكم" : "Dashboard";
}

@{
    string StoreStatusLabel(string status) => (status, isAr) switch
    {
        ("Active", true) => "نشط",
        ("Active", false) => "Active",
        ("PendingProvisioning", true) => "قيد الإعداد",
        ("PendingProvisioning", false) => "Pending",
        ("Suspended", true) => "معلق",
        ("Suspended", false) => "Suspended",
        _ => status
    };
    string StoreStatusBadge(string status) => status switch
    {
        "Active" => "bg-success",
        "PendingProvisioning" => "bg-warning text-dark",
        "Suspended" => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-shop"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">@Model.TotalStores</div>
                    <div class="text-muted small">@(isAr ? "إجمالي المتاجر" : "Total Stores")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold text-success">@Model.ActiveStores</div>
                    <div class="text-muted small">@(isAr ? "متاجر نشطة" : "Active Stores")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold text-warning">@Model.PendingStores</div>
                    <div class="text-muted small">@(isAr ? "قيد الإعداد" : "Pending Setup")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-secondary bg-opacity-10 text-secondary">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">@Model.TotalMerchants</div>
                    <div class="text-muted small">@(isAr ? "التجار" : "Merchants")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h6 class="mb-0 fw-semibold">
            <i class="bi bi-clock me-1"></i>
            @(isAr ? "آخر المتاجر المسجلة" : "Recently Registered Stores")
        </h6>
        <a asp-area="PlatformAdmin" asp-controller="PlatformStores" asp-action="Index"
           class="btn btn-sm btn-outline-primary">
            @(isAr ? "عرض الكل" : "View All")
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.RecentStores.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-shop fs-1 d-block mb-2 opacity-25"></i>
                <p>@(isAr ? "لا توجد متاجر بعد" : "No stores yet")</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>@(isAr ? "المتجر" : "Store")</th>
                            <th>@(isAr ? "المالك" : "Owner")</th>
                            <th>@(isAr ? "الحالة" : "Status")</th>
                            <th>@(isAr ? "تاريخ الإنشاء" : "Created")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var store in Model.RecentStores)
                        {
                            <tr>
                                <td>
                                    <div class="fw-medium">@store.StoreName</div>
                                    @if (!string.IsNullOrEmpty(store.StoreNameAr))
                                    {
                                        <div class="text-muted small">@store.StoreNameAr</div>
                                    }
                                    <div class="text-muted small font-monospace">@store.Slug</div>
                                </td>
                                <td>
                                    <div class="fw-medium small">@store.OwnerName</div>
                                    <div class="text-muted" style="font-size:0.75rem;">@store.OwnerEmail</div>
                                </td>
                                <td>
                                    <span class="badge badge-status @StoreStatusBadge(store.Status.ToString())">
                                        @StoreStatusLabel(store.Status.ToString())
                                    </span>
                                </td>
                                <td class="text-muted small">@store.CreatedAt.ToString("yyyy/MM/dd")</td>
                                <td>
                                    <a asp-area="PlatformAdmin" asp-controller="PlatformStores"
                                       asp-action="Details" asp-route-id="@store.Id"
                                       class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
