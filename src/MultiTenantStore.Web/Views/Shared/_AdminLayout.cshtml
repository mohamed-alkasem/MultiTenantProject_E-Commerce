@{
    string lang = Context.Request.Cookies["admin_lang"] ?? "ar";
    bool isAr = lang == "ar";
    string dir = isAr ? "rtl" : "ltr";
    string bootstrapCss = isAr
        ? "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css"
        : "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css";
    string userName = User.Identity?.Name ?? (isAr ? "المدير" : "Admin");
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(isAr ? "إدارة المنصة" : "Platform Admin") - @ViewData["Title"]</title>
    <link rel="stylesheet" href="@bootstrapCss" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&display=swap" />
    <style>
        * { font-family: 'Tajawal', sans-serif; }
        body { background: #f0f2f5; }

        .admin-sidebar {
            width: 260px;
            min-height: 100vh;
            background: linear-gradient(180deg, #1a1f36 0%, #2c3154 100%);
            position: fixed;
            top: 0;
            @(isAr ? "right" : "left"): 0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }
        .admin-sidebar .brand {
            padding: 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .admin-sidebar .brand-icon {
            width: 40px; height: 40px;
            background: linear-gradient(135deg, #6c63ff, #3ecf8e);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem; color: white;
        }
        .admin-sidebar .nav-section {
            padding: 0.5rem 0;
            flex: 1;
            overflow-y: auto;
        }
        .admin-sidebar .nav-label {
            padding: 0.75rem 1.25rem 0.25rem;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: rgba(255,255,255,0.35);
        }
        .admin-sidebar .nav-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.65rem 1.25rem;
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            border-radius: 0;
            font-size: 0.875rem;
            transition: all 0.15s;
        }
        .admin-sidebar .nav-link:hover {
            color: white;
            background: rgba(255,255,255,0.08);
        }
        .admin-sidebar .nav-link.active {
            color: white;
            background: rgba(108,99,255,0.3);
            border-@(isAr ? "right" : "left"): 3px solid #6c63ff;
        }
        .admin-sidebar .nav-link i { font-size: 1rem; min-width: 18px; }

        .admin-main {
            @(isAr ? "margin-right" : "margin-left"): 260px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .admin-topbar {
            background: white;
            border-bottom: 1px solid #e5e7eb;
            padding: 0.75rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .admin-content { padding: 1.5rem; flex: 1; }

        .stat-card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        }
        .stat-card .stat-icon {
            width: 48px; height: 48px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem;
        }
        .badge-status { font-size: 0.75rem; }
        .table th { font-size: 0.8rem; font-weight: 600; }

        @@media (max-width: 768px) {
            .admin-sidebar { transform: translateX(@(isAr ? "100%" : "-100%")); }
            .admin-sidebar.mobile-open { transform: translateX(0) !important; }
            .admin-main { @(isAr ? "margin-right" : "margin-left"): 0; }
            .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 999; }
            .sidebar-overlay.active { display: block; }
        }
        .mobile-menu-btn { display: none; }
        @@media (max-width: 768px) { .mobile-menu-btn { display: flex; } }
    </style>
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="brand d-flex align-items-center gap-2">
            <div class="brand-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
            <div>
                <div class="text-white fw-bold" style="font-size:0.9rem;">@(isAr ? "إدارة المنصة" : "Platform Admin")</div>
                <div style="color:rgba(255,255,255,0.4);font-size:0.7rem;">MultiTenantStore</div>
            </div>
        </div>

        <nav class="nav-section">
            <div class="nav-label">@(isAr ? "القائمة الرئيسية" : "Main Menu")</div>

            @{
                string controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                bool isDashboard = controller == "PlatformDashboard";
                bool isStores = controller == "PlatformStores";
                bool isPlans = controller == "PlatformPlans";
                bool isSubscriptions = controller == "PlatformSubscriptions";
            }

            <a asp-area="PlatformAdmin" asp-controller="PlatformDashboard" asp-action="Index"
               class="nav-link @(isDashboard ? "active" : "")">
                <i class="bi bi-speedometer2"></i>
                @(isAr ? "لوحة التحكم" : "Dashboard")
            </a>
            <a asp-area="PlatformAdmin" asp-controller="PlatformStores" asp-action="Index"
               class="nav-link @(isStores ? "active" : "")">
                <i class="bi bi-shop"></i>
                @(isAr ? "المتاجر" : "Stores")
            </a>
            <a asp-area="PlatformAdmin" asp-controller="PlatformPlans" asp-action="Index"
               class="nav-link @(isPlans ? "active" : "")">
                <i class="bi bi-layers"></i>
                @(isAr ? "خطط الاشتراك" : "Subscription Plans")
            </a>
            <a asp-area="PlatformAdmin" asp-controller="PlatformSubscriptions" asp-action="Index"
               class="nav-link @(isSubscriptions ? "active" : "")">
                <i class="bi bi-credit-card"></i>
                @(isAr ? "الاشتراكات" : "Subscriptions")
            </a>
        </nav>

        <div style="padding:1rem 1.25rem; border-top:1px solid rgba(255,255,255,0.1);">
            <div style="color:rgba(255,255,255,0.5);font-size:0.7rem;">@(isAr ? "جلسة إدارية محمية" : "Secured Admin Session")</div>
        </div>
    </aside>

    <div class="admin-main">
        <div class="admin-topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-outline-secondary mobile-menu-btn" onclick="toggleSidebar()">
                    <i class="bi bi-list fs-5"></i>
                </button>
                <h6 class="mb-0 fw-semibold" style="font-size:0.9rem;">@ViewData["Title"]</h6>
            </div>
            <div class="d-flex align-items-center gap-3">
                @* Language toggle *@
                <form asp-area="PlatformAdmin" asp-controller="AdminAccount" asp-action="SetLanguage" method="post" class="d-inline">
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <input type="hidden" name="lang" value="@(isAr ? "en" : "ar")" />
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-secondary px-3" style="font-size:0.8rem;">
                        @(isAr ? "English" : "عربي")
                    </button>
                </form>

                <div class="d-flex align-items-center gap-2">
                    <div style="width:34px;height:34px;background:linear-gradient(135deg,#6c63ff,#3ecf8e);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:0.8rem;font-weight:700;">
                        @(userName.Length > 0 ? userName[0].ToString().ToUpper() : "A")
                    </div>
                    <div style="font-size:0.82rem;">
                        <div class="fw-medium">@userName</div>
                        <div class="text-muted" style="font-size:0.7rem;">@(isAr ? "مدير المنصة" : "Platform Admin")</div>
                    </div>
                </div>

                <form asp-area="PlatformAdmin" asp-controller="AdminAccount" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            title="@(isAr ? "تسجيل الخروج" : "Sign out")"
                            onclick="return confirm('@(isAr ? "هل تريد تسجيل الخروج؟" : "Are you sure you want to sign out?")')">
                        <i class="bi bi-box-arrow-right"></i>
                        <span class="d-none d-md-inline" style="font-size:0.8rem;">@(isAr ? "خروج" : "Sign out")</span>
                    </button>
                </form>
            </div>
        </div>

        <main class="admin-content">
            @if (TempData["SuccessMessage"] is string success)
            {
                <div class="alert alert-success alert-dismissible fade show py-2 mb-3" role="alert">
                    <i class="bi bi-check-circle-fill me-1"></i> @success
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] is string error)
            {
                <div class="alert alert-danger alert-dismissible fade show py-2 mb-3" role="alert">
                    <i class="bi bi-exclamation-circle-fill me-1"></i> @error
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            var sidebar = document.getElementById('adminSidebar');
            var overlay = document.getElementById('sidebarOverlay');
            sidebar.classList.toggle('mobile-open');
            overlay.classList.toggle('active');
        }
    </script>
</body>
</html>
