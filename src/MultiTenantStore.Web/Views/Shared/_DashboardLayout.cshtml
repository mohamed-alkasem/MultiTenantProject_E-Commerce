@{
    var dashLang = Context.Request.Cookies["dash_lang"] ?? "ar";
    bool dashIsAr = dashLang == "ar";
    string dashDir = dashIsAr ? "rtl" : "ltr";
    string dashBootstrapCss = dashIsAr
        ? "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css"
        : "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css";
}
<!DOCTYPE html>
<html lang="@dashLang" dir="@dashDir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @(dashIsAr ? "لوحة التحكم" : "Dashboard")</title>
    <link rel="stylesheet" href="@dashBootstrapCss" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&display=swap" />
    <style>
        * { font-family: 'Tajawal', sans-serif; }
        body { background-color: #f0f2f5; margin: 0; }

        .sidebar {
            width: 260px;
            min-height: 100vh;
            background: linear-gradient(180deg, #1a2332 0%, #243447 100%);
            position: fixed;
            @(dashIsAr ? "right" : "left"): 0;
            top: 0;
            z-index: 1000;
            overflow-y: auto;
            transition: transform 0.3s ease;
            box-shadow: @(dashIsAr ? "-2px 0" : "2px 0") 10px rgba(0,0,0,0.15);
        }
        .sidebar-logo {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .sidebar-logo .logo-icon {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, #3498db, #2ecc71);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; color: white;
        }
        .sidebar-logo h5 { color: #fff; margin: 0; font-size: 1rem; font-weight: 600; }
        .sidebar-logo small { color: rgba(255,255,255,0.45); font-size: 0.72rem; }

        .nav-section-label {
            padding: 1rem 1.5rem 0.3rem;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: rgba(255,255,255,0.3);
            font-weight: 500;
        }
        .sidebar-nav-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.65rem 1.5rem;
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            font-size: 0.875rem;
            transition: all 0.2s;
            border-@(dashIsAr ? "right" : "left"): 3px solid transparent;
        }
        .sidebar-nav-link:hover {
            color: #fff;
            background: rgba(255,255,255,0.07);
            border-@(dashIsAr ? "right" : "left")-color: rgba(255,255,255,0.3);
        }
        .sidebar-nav-link.active {
            color: #fff;
            background: rgba(52,152,219,0.15);
            border-@(dashIsAr ? "right" : "left")-color: #3498db;
        }
        .sidebar-nav-link i { font-size: 1rem; width: 1.25rem; text-align: center; }

        .main-content { @(dashIsAr ? "margin-right" : "margin-left"): 260px; min-height: 100vh; display: flex; flex-direction: column; }

        .top-navbar {
            background: #fff;
            border-bottom: 1px solid #e9ecef;
            padding: 0 1.75rem;
            height: 62px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 900;
            box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        }
        .top-navbar .page-title { font-size: 0.95rem; font-weight: 600; color: #344054; }
        .top-navbar .user-info { font-size: 0.8rem; color: #6c757d; }

        .page-content { padding: 1.75rem; flex: 1; }

        .card {
            border: none;
            box-shadow: 0 1px 6px rgba(0,0,0,0.06);
            border-radius: 12px;
        }
        .card-header { background: none; border-bottom: 1px solid #f0f2f5; padding: 1rem 1.25rem; font-weight: 600; }

        .stat-card {
            border-radius: 12px;
            border: none;
            overflow: hidden;
        }
        .stat-icon {
            width: 48px; height: 48px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.25rem;
        }

        .table th { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #6c757d; border-top: none; }
        .table td { font-size: 0.875rem; vertical-align: middle; }

        .badge-status {
            font-size: 0.72rem;
            padding: 0.3em 0.75em;
            border-radius: 20px;
            font-weight: 500;
        }

        .btn-action { padding: 0.3rem 0.6rem; font-size: 0.8rem; }

        /* Enhanced polish */
        .card { border: none; box-shadow: 0 1px 6px rgba(0,0,0,0.06); border-radius: 12px; }
        .card-header { background: #fff; border-bottom: 1px solid #f0f2f5; padding: 0.875rem 1.25rem; font-weight: 600; font-size: 0.875rem; border-radius: 12px 12px 0 0 !important; }
        .form-control, .form-select { border-radius: 8px; font-size: 0.875rem; }
        .form-control:focus, .form-select:focus { border-color: #3498db; box-shadow: 0 0 0 3px rgba(52,152,219,0.15); }
        .btn { border-radius: 8px; font-size: 0.875rem; }
        .btn-primary { background: linear-gradient(135deg, #3498db, #2980b9); border: none; }
        .btn-primary:hover { background: linear-gradient(135deg, #2980b9, #1f6aa5); }
        .alert { border-radius: 10px; border: none; }

        @@media (max-width: 768px) {
            .sidebar { transform: translateX(@(dashIsAr ? "260px" : "-260px")); }
            .sidebar.mobile-open { transform: translateX(0); }
            .main-content { margin-right: 0; margin-left: 0; }
            .mobile-toggle { display: flex !important; }
        }
        .mobile-toggle { display: none; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<div class="sidebar" id="mainSidebar">
    <div class="sidebar-logo">
        <div class="logo-icon"><i class="bi bi-shop"></i></div>
        <div>
            <h5>@(dashIsAr ? "متجري" : "My Store")</h5>
            <small>@(dashIsAr ? "لوحة التحكم" : "Dashboard")</small>
        </div>
    </div>

    <nav>
        <p class="nav-section-label">@(dashIsAr ? "الرئيسية" : "MAIN")</p>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardHome" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardHome" asp-action="Index">
            <i class="bi bi-speedometer2"></i> @(dashIsAr ? "نظرة عامة" : "Overview")
        </a>

        <p class="nav-section-label">@(dashIsAr ? "الكتالوج" : "CATALOG")</p>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardCategories" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardCategories" asp-action="Index">
            <i class="bi bi-folder2-open"></i> @(dashIsAr ? "الفئات" : "Categories")
        </a>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardProducts" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardProducts" asp-action="Index">
            <i class="bi bi-box-seam"></i> @(dashIsAr ? "المنتجات" : "Products")
        </a>

        <p class="nav-section-label">@(dashIsAr ? "المبيعات" : "SALES")</p>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardOrders" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardOrders" asp-action="Index">
            <i class="bi bi-bag-check"></i> @(dashIsAr ? "الطلبات" : "Orders")
        </a>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardInvoices" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardInvoices" asp-action="Index">
            <i class="bi bi-receipt-cutoff"></i> @(dashIsAr ? "الفواتير" : "Invoices")
        </a>

        <p class="nav-section-label">@(dashIsAr ? "العملاء" : "CUSTOMERS")</p>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardCustomers" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardCustomers" asp-action="Index">
            <i class="bi bi-people"></i> @(dashIsAr ? "العملاء" : "Customers")
        </a>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardStaff" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardStaff" asp-action="Index">
            <i class="bi bi-person-badge"></i> @(dashIsAr ? "الموظفون" : "Staff")
        </a>

        <p class="nav-section-label">@(dashIsAr ? "الإعدادات" : "SETTINGS")</p>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardBranding" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardBranding" asp-action="Index">
            <i class="bi bi-palette"></i> @(dashIsAr ? "هوية المتجر" : "Branding")
        </a>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardSubscription" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardSubscription" asp-action="Index">
            <i class="bi bi-layers"></i> @(dashIsAr ? "اشتراكي" : "Subscription")
        </a>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardSettings" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardSettings" asp-action="Index">
            <i class="bi bi-gear"></i> @(dashIsAr ? "إعدادات المتجر" : "Settings")
        </a>
    </nav>
</div>

<div class="main-content">
    <div class="top-navbar">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-sm btn-outline-secondary mobile-toggle"
                    onclick="document.getElementById('mainSidebar').classList.toggle('mobile-open')">
                <i class="bi bi-list fs-5"></i>
            </button>
            <span class="page-title">@ViewData["Title"]</span>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="user-info d-none d-sm-inline">
                <i class="bi bi-person-circle"></i> @User.Identity?.Name
            </span>
            @* Language toggle *@
            <form method="post" action="/Dashboard/DashboardAccount/SetLanguage">
                @Html.AntiForgeryToken()
                <input type="hidden" name="lang" value="@(dashIsAr ? "en" : "ar")" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                <button type="submit" class="btn btn-sm btn-outline-secondary" style="font-size:0.75rem; padding:0.25rem 0.6rem;"
                        title="@(dashIsAr ? "Switch to English" : "التبديل للعربية")">
                    @(dashIsAr ? "EN" : "عر")
                </button>
            </form>
            <form asp-area="Dashboard" asp-controller="DashboardAccount" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger"
                        onclick="return confirm('@(dashIsAr ? "هل تريد تسجيل الخروج من لوحة التحكم؟" : "Do you want to logout?")')">
                    <i class="bi bi-box-arrow-left"></i>
                    <span class="d-none d-sm-inline">@(dashIsAr ? "خروج" : "Logout")</span>
                </button>
            </form>
        </div>
    </div>

    <div class="page-content">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
