<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لوحة التحكم</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" integrity="sha384-nU14brUcp6StFntEOun6y5mFWGdEKBhxPEfJ7yVsGAlItKkJYS2MBRQ1WMJb6MJ" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&display=swap" />
    <style>
        * { font-family: 'Tajawal', sans-serif; }
        body { background-color: #f0f2f5; margin: 0; }

        .sidebar {
            width: 260px;
            min-height: 100vh;
            background: linear-gradient(180deg, #1a2332 0%, #243447 100%);
            position: fixed;
            right: 0;
            top: 0;
            z-index: 1000;
            overflow-y: auto;
            transition: transform 0.3s ease;
            box-shadow: -2px 0 10px rgba(0,0,0,0.15);
        }
        .sidebar-logo {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .sidebar-logo .logo-icon {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, #3498db, #2ecc71);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; color: white;
        }
        .sidebar-logo h5 { color: #fff; margin: 0; font-size: 1rem; font-weight: 600; }
        .sidebar-logo small { color: rgba(255,255,255,0.45); font-size: 0.72rem; }

        .nav-section-label {
            padding: 1rem 1.5rem 0.3rem;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: rgba(255,255,255,0.3);
            font-weight: 500;
        }
        .sidebar-nav-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.65rem 1.5rem;
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            font-size: 0.875rem;
            transition: all 0.2s;
            border-right: 3px solid transparent;
        }
        .sidebar-nav-link:hover {
            color: #fff;
            background: rgba(255,255,255,0.07);
            border-right-color: rgba(255,255,255,0.3);
        }
        .sidebar-nav-link.active {
            color: #fff;
            background: rgba(52,152,219,0.15);
            border-right-color: #3498db;
        }
        .sidebar-nav-link i { font-size: 1rem; width: 1.25rem; text-align: center; }

        .main-content { margin-right: 260px; min-height: 100vh; display: flex; flex-direction: column; }

        .top-navbar {
            background: #fff;
            border-bottom: 1px solid #e9ecef;
            padding: 0 1.75rem;
            height: 62px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 900;
            box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        }
        .top-navbar .page-title { font-size: 0.95rem; font-weight: 600; color: #344054; }
        .top-navbar .user-info { font-size: 0.8rem; color: #6c757d; }

        .page-content { padding: 1.75rem; flex: 1; }

        .card {
            border: none;
            box-shadow: 0 1px 6px rgba(0,0,0,0.06);
            border-radius: 12px;
        }
        .card-header { background: none; border-bottom: 1px solid #f0f2f5; padding: 1rem 1.25rem; font-weight: 600; }

        .stat-card {
            border-radius: 12px;
            border: none;
            overflow: hidden;
        }
        .stat-icon {
            width: 48px; height: 48px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.25rem;
        }

        .table th { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #6c757d; border-top: none; }
        .table td { font-size: 0.875rem; vertical-align: middle; }

        .badge-status {
            font-size: 0.72rem;
            padding: 0.3em 0.75em;
            border-radius: 20px;
            font-weight: 500;
        }

        .btn-action { padding: 0.3rem 0.6rem; font-size: 0.8rem; }

        @@media (max-width: 768px) {
            .sidebar { transform: translateX(260px); }
            .sidebar.mobile-open { transform: translateX(0); }
            .main-content { margin-right: 0; }
            .mobile-toggle { display: flex !important; }
        }
        .mobile-toggle { display: none; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<div class="sidebar" id="mainSidebar">
    <div class="sidebar-logo">
        <div class="logo-icon"><i class="bi bi-shop"></i></div>
        <div>
            <h5>متجري</h5>
            <small>لوحة التحكم</small>
        </div>
    </div>

    <nav>
        <p class="nav-section-label">الرئيسية</p>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardHome" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardHome" asp-action="Index">
            <i class="bi bi-speedometer2"></i> نظرة عامة
        </a>

        <p class="nav-section-label">الكتالوج</p>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardCategories" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardCategories" asp-action="Index">
            <i class="bi bi-folder2-open"></i> الفئات
        </a>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardProducts" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardProducts" asp-action="Index">
            <i class="bi bi-box-seam"></i> المنتجات
        </a>

        <p class="nav-section-label">المبيعات</p>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardOrders" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardOrders" asp-action="Index">
            <i class="bi bi-bag-check"></i> الطلبات
        </a>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardInvoices" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardInvoices" asp-action="Index">
            <i class="bi bi-receipt-cutoff"></i> الفواتير
        </a>

        <p class="nav-section-label">العملاء</p>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardCustomers" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardCustomers" asp-action="Index">
            <i class="bi bi-people"></i> العملاء
        </a>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardStaff" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardStaff" asp-action="Index">
            <i class="bi bi-person-badge"></i> الموظفون
        </a>

        <p class="nav-section-label">الإعدادات</p>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardBranding" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardBranding" asp-action="Index">
            <i class="bi bi-palette"></i> هوية المتجر
        </a>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardSubscription" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardSubscription" asp-action="Index">
            <i class="bi bi-layers"></i> اشتراكي
        </a>
        <a class="sidebar-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardSettings" ? "active" : "")"
           asp-area="Dashboard" asp-controller="DashboardSettings" asp-action="Index">
            <i class="bi bi-gear"></i> إعدادات المتجر
        </a>
    </nav>
</div>

<div class="main-content">
    <div class="top-navbar">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-sm btn-outline-secondary mobile-toggle"
                    onclick="document.getElementById('mainSidebar').classList.toggle('mobile-open')">
                <i class="bi bi-list fs-5"></i>
            </button>
            <span class="page-title">@ViewData["Title"]</span>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="user-info d-none d-sm-inline">
                <i class="bi bi-person-circle"></i> @User.Identity?.Name
            </span>
            <form asp-area="Dashboard" asp-controller="DashboardAccount" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger"
                        onclick="return confirm('هل تريد تسجيل الخروج من لوحة التحكم؟')">
                    <i class="bi bi-box-arrow-left"></i>
                    <span class="d-none d-sm-inline">خروج</span>
                </button>
            </form>
        </div>
    </div>

    <div class="page-content">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
