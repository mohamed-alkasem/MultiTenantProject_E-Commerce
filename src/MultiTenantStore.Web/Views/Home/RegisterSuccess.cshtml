@{
    Layout = null;
    string lang = Context.Request.Cookies["site_lang"] ?? "ar";
    bool isAr = lang == "ar";
    string dir = isAr ? "rtl" : "ltr";
    string bootstrapCss = isAr
        ? "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css"
        : "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(isAr ? "تم التسجيل بنجاح" : "Registration Successful")</title>
    <link rel="stylesheet" href="@bootstrapCss" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&display=swap" />
    <style>
        * { font-family: 'Tajawal', sans-serif; }
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="bg-white rounded-4 p-5 text-center shadow-lg">
                    <div style="width:80px;height:80px;background:linear-gradient(135deg,#3ecf8e,#27ae60);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:2.5rem;color:white;">
                        <i class="bi bi-check-lg"></i>
                    </div>
                    <h4 class="fw-bold mb-2">@(isAr ? "تم تسجيل متجرك بنجاح!" : "Your Store is Registered!")</h4>
                    <p class="text-muted mb-4">
                        @(isAr
                            ? "تم إنشاء حسابك ومتجرك بنجاح. يمكنك الآن تسجيل الدخول إلى لوحة التحكم."
                            : "Your account and store have been created. You can now sign in to your dashboard.")
                    </p>
                    <a href="/Dashboard/DashboardAccount/Login" class="btn btn-primary w-100 py-2 fw-medium" style="background:linear-gradient(135deg,#3498db,#2980b9);border:none;">
                        <i class="bi bi-box-arrow-in-@(isAr ? "right" : "left") me-1"></i>
                        @(isAr ? "الذهاب إلى لوحة التحكم" : "Go to Dashboard")
                    </a>
                    <a href="/" class="btn btn-outline-secondary w-100 py-2 mt-2">
                        @(isAr ? "العودة للرئيسية" : "Back to Home")
                    </a>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
