@model RegisterMerchantViewModel
@{
    Layout = null;
    string lang = Context.Request.Cookies["site_lang"] ?? "ar";
    bool isAr = lang == "ar";
    string dir = isAr ? "rtl" : "ltr";
    string bootstrapCss = isAr
        ? "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css"
        : "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(isAr ? "تسجيل متجر جديد" : "Register New Store")</title>
    <link rel="stylesheet" href="@bootstrapCss" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&display=swap" />
    <style>
        * { font-family: 'Tajawal', sans-serif; }
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
            min-height: 100vh;
            padding: 2rem 0;
        }
        .register-card {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 25px 80px rgba(0,0,0,0.35);
        }
        .register-header {
            background: linear-gradient(135deg, #1a2332, #2d5986);
            border-radius: 20px 20px 0 0;
            padding: 2rem 2rem 1.5rem;
            color: #fff;
            text-align: center;
        }
        .step-badge {
            background: rgba(255,255,255,0.15);
            border-radius: 50px;
            padding: 0.25rem 0.85rem;
            font-size: 0.75rem;
            display: inline-block;
            margin-bottom: 0.75rem;
        }
        .register-body { padding: 2rem; }
        .section-title {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #9ca3af;
            font-weight: 600;
            margin-bottom: 0.75rem;
            margin-top: 1.5rem;
        }
        .form-label { font-size: 0.875rem; font-weight: 500; color: #374151; }
        .form-control:focus { border-color: #3498db; box-shadow: 0 0 0 0.2rem rgba(52,152,219,0.15); }
        .plan-card {
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            padding: 1rem;
            cursor: pointer;
            transition: all 0.2s;
            text-align: center;
        }
        .plan-card:hover { border-color: #3498db; background: #f0f7ff; }
        .plan-card.selected { border-color: #3498db; background: #e8f4fd; }
        .plan-price { font-size: 1.25rem; font-weight: 700; color: #1d4ed8; }
        .plan-price small { font-size: 0.7rem; font-weight: 400; color: #6b7280; }
        .btn-register {
            background: linear-gradient(135deg, #3498db, #2980b9);
            border: none;
            font-size: 1rem;
            padding: 0.75rem;
            border-radius: 10px;
        }
        .btn-register:hover { background: linear-gradient(135deg, #2980b9, #2471a3); }
        .lang-toggle {
            position: fixed;
            top: 1.25rem;
            @(isAr ? "left" : "right"): 1.25rem;
            z-index: 100;
        }
        .back-link { color: rgba(255,255,255,0.7); font-size: 0.875rem; text-decoration: none; }
        .back-link:hover { color: #fff; }
    </style>
</head>
<body>

    <form action="/Home/SetLanguage" method="post" class="lang-toggle">
        <input type="hidden" name="lang" value="@(isAr ? "en" : "ar")" />
        <input type="hidden" name="returnUrl" value="/Register" />
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-sm" style="background:rgba(255,255,255,0.1);color:#fff;border:1px solid rgba(255,255,255,0.3);">
            @(isAr ? "English" : "عربي")
        </button>
    </form>

    <div class="container">
        <div class="text-center mb-3">
            <a href="/" class="back-link">
                <i class="bi bi-arrow-@(isAr ? "right" : "left") me-1"></i>
                @(isAr ? "العودة للرئيسية" : "Back to Home")
            </a>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-7 col-xl-6">
                <div class="register-card">
                    <div class="register-header">
                        <div class="step-badge"><i class="bi bi-shop me-1"></i>@(isAr ? "تسجيل متجر جديد" : "New Store Registration")</div>
                        <h4 class="fw-bold mb-1">@(isAr ? "أنشئ متجرك الآن" : "Create Your Store")</h4>
                        <p style="color:rgba(255,255,255,0.6);font-size:0.875rem;margin:0;">
                            @(isAr ? "أدخل بياناتك لإنشاء حساب وبدء العمل" : "Enter your details to create an account and get started")
                        </p>
                    </div>

                    <div class="register-body">
                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                        {
                            <div class="alert alert-danger py-2 mb-3" role="alert">
                                <i class="bi bi-exclamation-circle-fill me-1"></i>
                                <span asp-validation-summary="All" class="d-inline"></span>
                            </div>
                        }

                        <form asp-action="Register" method="post">
                            @Html.AntiForgeryToken()

                            <p class="section-title">@(isAr ? "معلومات شخصية" : "Personal Information")</p>
                            <div class="row g-2">
                                <div class="col-6">
                                    <label asp-for="FirstName" class="form-label">@(isAr ? "الاسم الأول" : "First Name")</label>
                                    <input asp-for="FirstName" class="form-control" placeholder="@(isAr ? "محمد" : "John")" />
                                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                                </div>
                                <div class="col-6">
                                    <label asp-for="LastName" class="form-label">@(isAr ? "اسم العائلة" : "Last Name")</label>
                                    <input asp-for="LastName" class="form-control" placeholder="@(isAr ? "أحمد" : "Doe")" />
                                    <span asp-validation-for="LastName" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="mt-2">
                                <label asp-for="Email" class="form-label">@(isAr ? "البريد الإلكتروني" : "Email")</label>
                                <input asp-for="Email" class="form-control" type="email" placeholder="example@domain.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="row g-2 mt-0">
                                <div class="col-6">
                                    <label asp-for="Password" class="form-label">@(isAr ? "كلمة المرور" : "Password")</label>
                                    <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                                <div class="col-6">
                                    <label asp-for="ConfirmPassword" class="form-label">@(isAr ? "تأكيد كلمة المرور" : "Confirm Password")</label>
                                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••••" />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="mt-2">
                                <label asp-for="PhoneNumber" class="form-label">
                                    @(isAr ? "رقم الجوال" : "Phone Number")
                                    <span class="text-muted small">(optional)</span>
                                </label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="@(isAr ? "+966 5xx xxx xxx" : "+1 555 000 0000")" />
                            </div>

                            <p class="section-title">@(isAr ? "معلومات المتجر" : "Store Information")</p>

                            <div class="row g-2">
                                <div class="col-7">
                                    <label asp-for="StoreName" class="form-label">@(isAr ? "اسم المتجر" : "Store Name")</label>
                                    <input asp-for="StoreName" class="form-control" id="storeNameInput"
                                           placeholder="@(isAr ? "متجري للإلكترونيات" : "My Electronics Store")" />
                                    <span asp-validation-for="StoreName" class="text-danger small"></span>
                                </div>
                                <div class="col-5">
                                    <label asp-for="StoreSlug" class="form-label">@(isAr ? "معرف المتجر (Slug)" : "Store Slug")</label>
                                    <div class="input-group">
                                        <span class="input-group-text text-muted small">/</span>
                                        <input asp-for="StoreSlug" class="form-control" id="slugInput"
                                               placeholder="my-store" />
                                    </div>
                                    <span asp-validation-for="StoreSlug" class="text-danger small"></span>
                                    <div class="text-muted" style="font-size:0.7rem;">@(isAr ? "أحرف صغيرة وشرطات فقط" : "Lowercase letters & hyphens only")</div>
                                </div>
                            </div>

                            <p class="section-title">@(isAr ? "اختر خطة الاشتراك" : "Choose Subscription Plan")</p>

                            <div class="row g-2 mb-3">
                                @foreach (var plan in Model.Plans)
                                {
                                    <div class="col-4">
                                        <label class="plan-card @(Model.PlanCode == plan.Code ? "selected" : "")" for="plan_@plan.Code">
                                            <input type="radio" name="PlanCode" id="plan_@plan.Code" value="@plan.Code"
                                                   @(Model.PlanCode == plan.Code || (string.IsNullOrEmpty(Model.PlanCode) && plan.Code == "FREE") ? "checked" : "")
                                                   class="d-none" onchange="selectPlan(this)" />
                                            <div class="fw-bold mb-1">@(isAr && !string.IsNullOrEmpty(plan.NameAr) ? plan.NameAr : plan.Name)</div>
                                            @if (plan.PriceMonthly == 0)
                                            {
                                                <div class="plan-price">@(isAr ? "مجاني" : "Free")</div>
                                            }
                                            else
                                            {
                                                <div class="plan-price">$@plan.PriceMonthly<small>/@(isAr ? "شهر" : "mo")</small></div>
                                            }
                                        </label>
                                    </div>
                                }
                            </div>

                            <div class="mb-3">
                                <label class="form-label">@(isAr ? "دورة الفوترة" : "Billing Cycle")</label>
                                <div class="d-flex gap-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="BillingCycle" id="monthly" value="Monthly"
                                               @(Model.BillingCycle != "Yearly" ? "checked" : "") />
                                        <label class="form-check-label" for="monthly">@(isAr ? "شهري" : "Monthly")</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="BillingCycle" id="yearly" value="Yearly"
                                               @(Model.BillingCycle == "Yearly" ? "checked" : "") />
                                        <label class="form-check-label" for="yearly">
                                            @(isAr ? "سنوي" : "Yearly")
                                            <span class="badge bg-success text-white" style="font-size:0.65rem;">@(isAr ? "وفّر 20%" : "Save 20%")</span>
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary btn-register w-100 text-white fw-medium">
                                <i class="bi bi-shop me-1"></i>
                                @(isAr ? "إنشاء المتجر" : "Create My Store")
                            </button>

                            <p class="text-center text-muted small mt-3 mb-0">
                                @(isAr ? "لديك حساب بالفعل؟" : "Already have an account?")
                                <a href="/Dashboard/DashboardAccount/Login" class="text-decoration-none">
                                    @(isAr ? "سجّل دخولك" : "Sign in")
                                </a>
                            </p>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function selectPlan(input) {
            document.querySelectorAll('.plan-card').forEach(c => c.classList.remove('selected'));
            input.closest('.plan-card').classList.add('selected');
        }
        document.getElementById('storeNameInput').addEventListener('input', function () {
            var slug = this.value
                .toLowerCase()
                .replace(/\s+/g, '-')
                .replace(/[^a-z0-9-]/g, '')
                .replace(/-+/g, '-')
                .replace(/^-|-$/g, '');
            document.getElementById('slugInput').value = slug;
        });
    </script>
</body>
</html>
